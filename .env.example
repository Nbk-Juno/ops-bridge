# PostgreSQL
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name

# service_a database connection (uses Docker service name "db" as host)
DATABASE_URL=postgresql+psycopg2://your_postgres_user:your_postgres_password@db/your_database_name

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here

# RabbitMQ (uses Docker service name "rabbitmq" as host)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Test database — must exist locally before running tests
TEST_DATABASE_URL=postgresql+psycopg2://your_postgres_user:your_postgres_password@localhost:5432/opsbridge_test

# Test RabbitMQ — points to localhost for running tests outside Docker
TEST_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
